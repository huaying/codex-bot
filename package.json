{
  "name": "codex-discord-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prod": "npm run build && npm start",
    "check": "tsc --noEmit",
    "start:tmux": "bash scripts/tmux-supervisor.sh start",
    "stop:tmux": "bash scripts/tmux-supervisor.sh stop",
    "restart:tmux": "bash scripts/tmux-supervisor.sh restart",
    "status:tmux": "bash scripts/tmux-supervisor.sh status",
    "logs:tmux": "bash scripts/tmux-supervisor.sh logs",
    "attach:tmux": "bash scripts/tmux-supervisor.sh attach"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
