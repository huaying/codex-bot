DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me

# Recommended for fast command registration while developing.
DISCORD_GUILD_ID=

# Comma-separated Discord snowflake IDs.
ALLOWED_USER_IDS=
ALLOWED_GUILD_IDS=
ALLOWED_CHANNEL_IDS=

# Optional semicolon-separated id:path pairs for manual aliases/overrides.
# Example: WORKSPACES=bot:/Users/you/Dev/codex-bot;app:/Users/you/Dev/my-app
WORKSPACES=
# Comma- or semicolon-separated roots. Direct child folders become workspace ids.
WORKSPACE_ROOTS=/Users/you/Dev
DEFAULT_WORKSPACE_ID=codex-bot

CODEX_COMMAND=codex
CODEX_SANDBOX=workspace-write
CODEX_FULL_AUTO=true
CODEX_YOLO=false
CODEX_MODEL=
CODEX_PROFILE=
CODEX_TIMEOUT_SECONDS=840

# Optional JSON array appended to `codex exec`.
# Example: CODEX_EXTRA_ARGS_JSON=["--enable","some-feature"]
CODEX_EXTRA_ARGS_JSON=[]

AUTO_REGISTER_COMMANDS=true
LOG_LEVEL=info
DATA_DIR=.data

# Enables DM / @mention message sessions. Requires Message Content Intent for
# guild message text.
ENABLE_MESSAGE_SESSIONS=true
# Optional REST fallback for debugging if Gateway messageCreate events are not arriving.
ENABLE_DM_POLLING=false
DM_POLL_INTERVAL_SECONDS=3

# Safer default: guild channels require @mention for each prompt. DM always
# continues directly. Set true only for private bot-only channels/threads.
CONTINUE_GUILD_CHANNEL_SESSIONS=false
